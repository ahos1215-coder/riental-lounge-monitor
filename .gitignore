# =========================
# MEGRIBI repo .gitignore
# =========================

# root only
/lib/

# --- Python ---
__pycache__/
*.py[cod]
*.pyd
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.coverage
coverage/
htmlcov/
dist/
build/
*.egg-info/

# env files (local only)
.env
.env.*
!.env.example
.venv/
venv/
ENV/
env/

# --- Node / Next.js ---
node_modules/
.next/
out/
dist/
.turbo/
.vercel/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- OS / Editor ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Local backup / temp ---
*.bak
*.bak.*
*~
*.swp
*.tmp
*.zip
*.patch

# --- Project artifacts ---
artifacts/
data/ml_models/
supabase/.temp/

# Local runtime data (continuously written by the local collector; not fixtures)
data/data.json
data/log.jsonl

# Open-Meteo weather cache (multi_collect.py)
.cache/

# --- Claude Code local working dir (worktrees, session state) ---
.claude/

# --- Local LLM job artifacts / state ---
local_llm_spike_out/
data/aisekiya_alert_sent.txt

# --- Analytics service-account key (owner-only, NEVER commit) ---
# 週次アナリティクス(scripts/analytics_weekly_report.py)のGoogleサービスアカウント鍵。
# 閲覧専用ロボットの秘密鍵なので絶対にコミットしない。設定手順は docs/ANALYTICS_SETUP.md。
/secrets/
