        "@typescript-eslint/eslint-plugin": "8.46.4",
        "@typescript-eslint/parser": "8.46.4",
        "autoprefixer": "^10.4.22",
        "eslint": "^9",
        "eslint-config-next": "^16.0.10",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "7.0.1",
        "globals": "14.0.0",
        "postcss": "^8.5.6",
