        "date-fns": "^4.1.0",
        "framer-motion": "^12.38.0",
        "gray-matter": "^4.0.3",
        "lucide-react": "^1.7.0",
        "next": "^16.0.10",
        "react": "19.2.0",
        "react-dom": "19.2.0",
        "react-markdown": "^10.1.0",
        "recharts": "^3.5.0",
        "remark-gfm": "^4.0.1",
        "tailwind-merge": "^3.5.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@next/eslint-plugin-next": "^16.0.10",
