{
    "name": "frontend",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "facts:generate": "node scripts/generate-public-facts.mjs",
        "drafts:export": "node scripts/export-blog-draft.mjs",
        "smoke:blog-apis": "node scripts/smoke-blog-apis.mjs",
        "dev": "next dev",
        "dev:clean": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/clean-next-dev.ps1",
        "build": "next build",
