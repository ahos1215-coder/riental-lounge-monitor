  "ai_commentary": "\u5148\u9031\u306f\u3001\u9031\u672b\u306b\u304b\u3051\u3066\u6df7\u96d1\u304c\u4e0a\u304c\u308a\u3001\u91d1\u66dc\u304b\u3089\u571f\u66dc\u306e\u591c\u306b\u7279\u306b\u8cd1\u308f\u3044\u304c\u898b\u3089\u308c\u307e\u3057\u305f\u3002\n- \u91d1\u66dc\u30fb\u571f\u66dc\u306e\u30d4\u30fc\u30af\u30bf\u30a4\u30e0: \u307b\u307c\u6e80\u5e2d\u3068\u306a\u308b\u6642\u9593\u5e2f\u304c\u591a\u304f\u898b\u3089\u308c\u307e\u3057\u305f\u3002\n- \u5e73\u65e5\uff08\u6c34\u301c\u706b\uff09\u306e\u65e5\u4e2d\u5e73\u5747: \u5168\u4f53\u7684\u306b20%\u524d\u5f8c\u306e\u5229\u7528\u7387\u3067\u63a8\u79fb\u3057\u307e\u3057\u305f\u3002\n- \u65e5\u66dc\u65e5\u306f\u5348\u5f8c\u306e\u6642\u9593\u5e2f\u304c\u6700\u3082\u6df7\u307f\u3084\u3059\u3044\u50be\u5411\u3067\u3057\u305f\u3002\n\n\u6765\u9031\u3082\u9031\u672b\u3092\u4e2d\u5fc3\u306b\u6df7\u96d1\u304c\u4e88\u60f3\u3055\u308c\u3001\u7279\u306b\u591c\u9593\u306f\u9ad8\u3044\u8cd1\u308f\u3044\u304c\u671f\u5f85\u3067\u304d\u307e\u3059\u3002\n- \u91d1\u66dc\u30fb\u571f\u66dc\u306e\u591c: \u7d42\u76e4\u306b\u304b\u3051\u3066\u307b\u307c\u6e80\u5e2d\u3068\u306a\u308b\u6642\u9593\u304c\u7d9a\u304f\u898b\u8fbc\u307f\u3067\u3059\u3002\n- \u5e73\u65e5\u306e\u5e73\u5747\u5229\u7528\u7387: \u9031\u524d\u534a\u304b\u3089\u4e2d\u76e4\u306b\u304b\u3051\u306620%\u53f0\u3067\u306e\u63a8\u79fb\u304c\u898b\u8fbc\u307e\u308c\u307e\u3059\u3002\n- \u65e5\u66dc\u65e5\u306e\u6642\u9593\u5e2f: \u5348\u5f8c\u304b\u3089\u591c\u306b\u304b\u3051\u3066\u3001\u6df7\u96d1\u3059\u308b\u50be\u5411\u304c\u4e88\u6e2c\u3055\u308c\u307e\u3059\u3002"
}
