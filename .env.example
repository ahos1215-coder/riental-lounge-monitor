# === Supabase ===
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# === Backend (Flask) ===
TIMEZONE=Asia/Tokyo
ENABLE_FORECAST=1
FORECAST_MODEL_BUCKET=ml-models
FORECAST_MODEL_PREFIX=forecast/latest
FORECAST_MODEL_SCHEMA_VERSION=v7
FORECAST_MODEL_REFRESH_SEC=900
FORECAST_MODEL_CACHE_DIR=data/ml_models

# === ML Training ===
ML_TRAIN_DAYS=180
ML_TRAIN_LIMIT=120000
ML_TRAIN_STORE_ID=
ML_TRAIN_WEIGHT_PEAK=1.8
ML_TRAIN_WEIGHT_RAIN=1.8
ML_OPTUNA_ENABLED=1
ML_OPTUNA_TRIALS=30

# === Frontend (Next.js / Vercel) ===
# BACKEND_URL=https://your-render-url.onrender.com
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_SITE_URL=https://meguribi.jp

# === X (Twitter) 自動投稿 ===
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=
# SNS_POST_SECRET=
# SNS_POST_ALLOWED_STORE_SLUGS=nagasaki,shibuya,ebisu,shinjuku,umeda_ag,fukuoka

# === LINE Webhook ===
# LINE_CHANNEL_SECRET=
# LINE_CHANNEL_ACCESS_TOKEN=
# GEMINI_API_KEY=
# 週次アナリティクスのダイジェストをLINE Pushで受け取る宛先（自分のuserId or グループID）。
# multi_collect.py の相席屋アラート／check-pat-expiry.yml と同じ変数を共用する。未設定なら送信スキップ。
# LINE_USER_ID=

# === Cron ===
# CRON_SECRET=

# === 週次アナリティクス（オーナー専用・scripts/analytics_weekly_report.py） ===
# 設定手順の全量は docs/ANALYTICS_SETUP.md を参照。未設定なら安全に no-op する。
# GA4_PROPERTY_ID=          # GA4 プロパティ ID（数字のみ。例 493xxxxxx）
# GA_SERVICE_ACCOUNT_JSON=  # サービスアカウント鍵のパス（既定: secrets/ga-service-account.json）
# GSC_SITE_URL=https://www.meguribi.jp/   # Search Console プロパティ（URLプレフィックス・末尾スラッシュ必須）
