# === Supabase ===
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# === Backend (Flask) ===
TIMEZONE=Asia/Tokyo
ENABLE_FORECAST=1
FORECAST_MODEL_BUCKET=ml-models
FORECAST_MODEL_PREFIX=forecast/latest
FORECAST_MODEL_SCHEMA_VERSION=v2
FORECAST_MODEL_REFRESH_SEC=900
FORECAST_MODEL_CACHE_DIR=data/ml_models

# === ML Training ===
ML_TRAIN_DAYS=180
ML_TRAIN_LIMIT=120000
ML_TRAIN_STORE_ID=
ML_TRAIN_WEIGHT_PEAK=1.8
ML_TRAIN_WEIGHT_RAIN=1.8
ML_OPTUNA_ENABLED=1
ML_OPTUNA_TRIALS=30

